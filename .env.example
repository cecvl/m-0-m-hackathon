PORT=4000
AUTO_RELEASE_DAYS=7
PLATFORM_COMMISSION_RATE=0.1
REQUIRE_CALLBACK_SIGNATURE=false
MPESA_CALLBACK_SECRET=dev-mpesa-callback-secret

# Persistence (Phase 1 DB)
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
MONGO_DB_NAME=bookmarket

# Provider switches
PAYMENT_PROVIDER=mock
SMS_PROVIDER=mock

# Safaricom Daraja (Sandbox)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_INITIATOR_NAME=
MPESA_INITIATOR_PASSWORD=

# Africa's Talking (optional for now)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=
